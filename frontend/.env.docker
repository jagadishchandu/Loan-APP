# Expo Public env vars
# When running locally, the host machine talks to the backend on http://localhost:8001
# When testing on a real phone via Expo Go, replace "localhost" with your LAN IP, e.g. http://192.168.1.5:8001
EXPO_PUBLIC_BACKEND_URL=http://52.140.49.36:8001

# Allow Metro to be reached from your phone in dev (LAN)
EXPO_PACKAGER_HOSTNAME=52.140.49.36
